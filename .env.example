# ──────────────────────────────────────────────────────────────────────────
# Supabase connection
#
# Copy this file to `.env.local` and fill in the values from your Supabase
# project (Project Settings → API). `.env.local` is git-ignored.
#
# The service-role key bypasses Row Level Security and must NEVER be exposed to
# the browser. It is only read inside server-only modules (Route Handlers /
# server components), so it is intentionally *not* prefixed with NEXT_PUBLIC_.
# The client never talks to Supabase directly — it goes through our /api routes.
# ──────────────────────────────────────────────────────────────────────────

# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# Service-role secret (server only).
SUPABASE_SERVICE_ROLE_KEY=
